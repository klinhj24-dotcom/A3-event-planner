{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build:vercel",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/staff-reminders",      "schedule": "0 13 * * *" },
    { "path": "/api/cron/debrief-reminders",    "schedule": "0 14 * * *" },
    { "path": "/api/cron/event-reminders",      "schedule": "0 15 * * *" },
    { "path": "/api/cron/band-reminders",       "schedule": "0 16 * * *" },
    { "path": "/api/cron/open-mic",             "schedule": "0 17 * * *" },
    { "path": "/api/cron/auto-email-cal-sync",  "schedule": "0 18 * * *" }
  ]
}
